prefix_rule(pattern=["bun", "--version"], decision="allow")
prefix_rule(pattern=["bun", "run", "validate"], decision="allow")
prefix_rule(pattern=["bun", "run", "validate:decisions"], decision="allow")
prefix_rule(pattern=["bun", "run", "pack:skills"], decision="allow")
prefix_rule(pattern=["bun", "run", "check"], decision="allow")
prefix_rule(pattern=["bun", "scripts/validate.ts"], decision="allow")
prefix_rule(pattern=["bun", "scripts/validate-decisions.ts"], decision="allow")
prefix_rule(pattern=["bun", "scripts/pack-skills.ts"], decision="allow")
prefix_rule(pattern=["bun", "test"], decision="allow")
prefix_rule(pattern=["bun", "run", "deploy:package"], decision="prompt")
prefix_rule(pattern=["bun", "install"], decision="prompt")
prefix_rule(pattern=["bun", "add"], decision="prompt")
prefix_rule(pattern=["bun", "remove"], decision="prompt")
prefix_rule(pattern=["bun", "update"], decision="prompt")
prefix_rule(pattern=["bun", "x"], decision="prompt")
prefix_rule(pattern=["bunx"], decision="prompt")
