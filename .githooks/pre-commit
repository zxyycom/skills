#!/bin/sh
set -eu

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

if ! command -v bun >/dev/null 2>&1; then
  echo "bun is required to update skill-package-lock.json before commit." >&2
  exit 1
fi

bun scripts/hash-skills.ts --write --quiet
if ! git diff --quiet -- skill-package-lock.json; then
  git add skill-package-lock.json
fi
