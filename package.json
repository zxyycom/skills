{
  "name": "skills-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "bun": ">=1.3",
    "pnpm": ">=11"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "validate": "bun scripts/validate.ts",
    "test:change-plan-cli": "bun tools/change-plan/tests/run.ts",
    "test:decision-records-cli": "bun tools/decision-records/tests/run.ts",
    "test:check": "bun scripts/check.test.ts",
    "test:generated-file": "bun scripts/lib/generated-file.test.ts",
    "test:version-control": "bun tools/shared/tests/version-control.test.ts",
    "test:investigation-report-check": "bun tools/investigation-report/tests/run.ts",
    "test:skill-validator": "bun tools/skill-validator/tests/run.ts",
    "test:test-evidence-cli": "bun tools/test-evidence/tests/run.ts",
    "test:skill-updater": "bun tools/skill-updater/tests/run.ts",
    "hash:skills": "bun scripts/hash-skills.ts",
    "pack:skills": "bun scripts/pack-skills.ts",
    "setup-hooks": "bun scripts/setup-git-hooks.ts",
    "sync:change-plan-cli": "bun scripts/build/change-plan.ts --write",
    "check:change-plan-cli": "bun scripts/build/change-plan.ts --check",
    "sync:decision-records-cli": "bun scripts/build/decision-records.ts --write",
    "check:decision-records-cli": "bun scripts/build/decision-records.ts --check",
    "sync:skill-validator": "bun scripts/build/skill-validator.ts --write",
    "check:skill-validator": "bun scripts/build/skill-validator.ts --check",
    "sync:investigation-report-check": "bun scripts/build/investigation-report.ts --write",
    "check:investigation-report-check": "bun scripts/build/investigation-report.ts --check",
    "check:investigations": "bun tools/investigation-report/src/cli.ts --root .",
    "check:decisions": "bun tools/decision-records/src/cli.ts check --root .",
    "sync:test-evidence-cli": "bun scripts/build/test-evidence.ts --write",
    "check:test-evidence-cli": "bun scripts/build/test-evidence.ts --check",
    "sync:test-evidence-fixture": "bun tools/test-evidence/tests/build-fixture.ts --write",
    "check:test-evidence-fixture": "bun tools/test-evidence/tests/build-fixture.ts --check",
    "sync:skill-updaters": "bun scripts/build/skill-updaters.ts --write",
    "check:skill-updaters": "bun scripts/build/skill-updaters.ts --check",
    "check": "bun scripts/check.ts"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/picomatch": "^4.0.3",
    "@typescript/native-preview": "7.0.0-dev.20260630.1",
    "@valibot/to-json-schema": "1.7.1",
    "commander": "^13.1.0",
    "fast-glob": "^3.3.3",
    "fflate": "^0.8.3",
    "github-slugger": "^2.0.0",
    "json-schema-to-typescript": "15.0.4",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-to-string": "^4.0.0",
    "picomatch": "4.0.5",
    "simple-git": "3.36.0",
    "valibot": "^1.4.2",
    "yaml": "^2.9.0"
  }
}
