{
  "name": "skills-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "bun": ">=1.3",
    "pnpm": ">=11"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "validate": "bun scripts/validate.ts",
    "test:decision-records-cli": "bun scripts/decision-records/tests/run.ts",
    "test:check": "bun scripts/check.test.ts",
    "test:generated-file": "bun scripts/lib/generated-file.test.ts",
    "test:skill-validator": "bun scripts/skill-validator/tests/run.ts",
    "test:test-evidence-cli": "bun scripts/test-evidence/tests/run.ts",
    "test:skill-updater": "bun scripts/templates/update-skill/tests/run.ts",
    "hash:skills": "bun scripts/hash-skills.ts",
    "pack:skills": "bun scripts/pack-skills.ts",
    "setup-hooks": "bun scripts/setup-git-hooks.ts",
    "sync:decision-records-cli": "bun scripts/decision-records/build.ts --write",
    "check:decision-records-cli": "bun scripts/decision-records/build.ts --check",
    "sync:skill-validator": "bun scripts/skill-validator/build.ts --write",
    "check:skill-validator": "bun scripts/skill-validator/build.ts --check",
    "sync:test-evidence-cli": "bun scripts/test-evidence/build.ts --write",
    "check:test-evidence-cli": "bun scripts/test-evidence/build.ts --check",
    "sync:test-evidence-fixture": "bun scripts/test-evidence/tests/build-fixture.ts --write",
    "check:test-evidence-fixture": "bun scripts/test-evidence/tests/build-fixture.ts --check",
    "sync:skill-updaters": "bun scripts/sync-skill-updaters.ts --write",
    "check:skill-updaters": "bun scripts/sync-skill-updaters.ts --check",
    "check": "bun scripts/check.ts"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/picomatch": "^4.0.3",
    "@typescript/native-preview": "7.0.0-dev.20260630.1",
    "@valibot/to-json-schema": "1.7.1",
    "commander": "^13.1.0",
    "fast-glob": "^3.3.3",
    "fflate": "^0.8.3",
    "github-slugger": "^2.0.0",
    "json-schema-to-typescript": "15.0.4",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-to-string": "^4.0.0",
    "picomatch": "4.0.5",
    "valibot": "^1.4.2",
    "yaml": "^2.9.0"
  }
}
